#!/bin/sh
set -e

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" --no-use
[ -s "$NVM_DIR/alias/default" ] && nvm use default --silent 2>/dev/null || true

echo "\n[1/3] Verify: ESLint"
./node_modules/.bin/eslint .

echo "\n[2/3] Verify: Tests"
./node_modules/.bin/jest

echo "\n[3/3] Verify: Coverage (thresholds: 80%)"
./node_modules/.bin/jest --coverage --silent

echo "\nAll pre-commit checks passed."
